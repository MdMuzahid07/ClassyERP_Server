# Database Configuration
DB_URL=mongodb://localhost:27017/classy_erp
PORT=5000
NODE_ENV=development
DATABASE_NAME=classy_erp

# Cloudinary Configuration (Keep placeholders if not using Cloudinary)
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name


# JWT Secrets Configuration
JWT_ACCESS_SECRET_KEY=your_jwt_access_secret_key_here_must_be_long_and_secure
JWT_REFRESH_SECRET_KEY=your_jwt_refresh_secret_key_here_must_be_long_and_secure
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# Admin Seeding Credentials
ADMIN_EMAIL=admin@classyerp.com
ADMIN_PASSWORD=AdminPass123!

# Security & Business Settings
BCRYPT_SALT_ROUND=12
LOW_STOCK_THRESHOLD=5